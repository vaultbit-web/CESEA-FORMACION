# CESEA Formación · variables de entorno locales
# Copiar a .env y rellenar con los valores reales del Supabase de Dokploy.
# El archivo .env está en .gitignore — nunca se commitea.

# URL pública del Supabase desplegado en Dokploy
SUPABASE_URL=http://cesea-formacion-supabase-9ccf70-89-116-38-126.traefik.me

# anon key — pública por diseño, va al frontend (index.html)
ANON_KEY=

# service_role key — solo para migración inicial desde Node, NUNCA al frontend
SERVICE_ROLE_KEY=

# Postgres password — solo si necesitas conectar con psql (opcional)
POSTGRES_PASSWORD=
